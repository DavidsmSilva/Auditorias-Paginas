# --- Helper functions ---

# Get all tools for a given phase
tools_by_phase() {
    local phase="$1"
    local result=()
    for tool in "${!TOOL_PHASE[@]}"; do
        if [[ "${TOOL_PHASE[$tool]}" == "$phase" ]]; then
            result+=("$tool")
        fi
    done
    # Sort by name for deterministic output
    IFS=$'\n' result=($(printf '%s\n' "${result[@]}" | sort)); unset IFS
    # 🛡️ printf instead of echo: each tool on its own line → safe word splitting
    #    Prev: echo "${result[@]}" collapsed everything space-separated, which
    #    broke when callers relied on word splitting (esp. with "SCA + SBOM" phase)
    printf '%s\n' "${result[@]}"
}

# Get install method for a tool
tool_method() {
    local tool="$1"
    echo "${TOOL_METHOD[$tool]:-apt}"
}

# Get package name for a tool
tool_pkg() {
    local tool="$1"
    echo "${TOOL_PKG[$tool]:-$tool}"
}

# Get binary name for a tool
tool_bin() {
    local tool="$1"
    echo "${TOOL_BIN[$tool]:-$tool}"
}

# Get description for a tool
tool_desc() {
    local tool="$1"
    echo "${TOOL_DESC[$tool]:-No description available}"
}

# Get phase for a tool
tool_phase() {
    local tool="$1"
    echo "${TOOL_PHASE[$tool]:-Unknown}"
}

# Check if tool is already installed
tool_installed() {
    local tool="$1"
    local bin
    bin=$(tool_bin "$tool")
    command -v "$bin" &>/dev/null
}

# Count tools in a phase
phase_tool_count() {
    local phase="$1"
    local count=0
    for tool in "${!TOOL_PHASE[@]}"; do
        [[ "${TOOL_PHASE[$tool]}" == "$phase" ]] && ((count++))
    done
    echo "$count"
}

# All phase names
ALL_PHASES=("Assessment" "Malware Analysis" "Brand Protection" "Incident Response" "SAST" "SCA + SBOM")

# Print tool count per phase
phase_summary() {
    echo "  Fase                Herramientas"
    echo "  ─────────────────────────────────────"
    for phase in "${ALL_PHASES[@]}"; do
        local count
        count=$(phase_tool_count "$phase")
        printf "  %-20s %3d\n" "${phase}:" "$count"
    done
    printf "  %-20s %3d\n" "TOTAL:" "$(phase_tool_count_all)"
}

phase_tool_count_all() {
    local total=0
    for tool in "${!TOOL_PHASE[@]}"; do
        ((total++))
    done
    echo "$total"
}
